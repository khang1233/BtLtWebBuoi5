@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="glass-panel text-center p-5 my-5 col-lg-7 mx-auto">
    <div class="mb-4">
        <i class="bi bi-shield-slash-fill text-danger" style="font-size: 5rem;"></i>
    </div>
    <h1 class="h2 fw-extrabold text-light mb-3">Từ Chối Truy Cập (Access Denied)</h1>
    <p class="lead text-secondary mb-4">
        Tài khoản của bạn không có đủ đặc quyền hoặc vai trò (Roles) cần thiết để truy cập vào phân vùng hệ thống này.
    </p>
    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-premium-primary">
            <i class="bi bi-house-door me-2"></i> Trở về Trang chủ
        </a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-box-arrow-right me-2"></i> Đăng nhập tài khoản khác
                </button>
            </form>
        }
    </div>
</div>
