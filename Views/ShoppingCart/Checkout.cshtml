@model Baitaptuan5.Models.Order
@{
    ViewData["Title"] = "Thanh Toán - Shop Khang";
}

<div class="glass-panel p-5 my-4" style="max-width: 650px; margin: 0 auto;">
    <h2 class="h3 fw-bold mb-4 text-center">
        <i class="bi bi-shield-check text-emerald me-2"></i> Thông tin giao hàng
    </h2>
    <p class="text-secondary text-center mb-5">Vui lòng cung cấp chính xác địa chỉ và thông tin ghi chú để chúng tôi giao hàng nhanh nhất.</p>

    <form asp-action="Checkout" method="post">
        @Html.AntiForgeryToken()

        <div class="custom-form-group mb-4">
            <label asp-for="ShippingAddress" class="form-label text-secondary fw-semibold mb-2">Địa chỉ giao hàng</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-info">
                    <i class="bi bi-geo-alt-fill"></i>
                </span>
                <input asp-for="ShippingAddress" class="form-control custom-form-control" placeholder="Số nhà, tên đường, phường/xã, quận/huyện..." />
            </div>
            <span asp-validation-for="ShippingAddress" class="text-danger small mt-1 d-block"></span>
        </div>

        <div class="custom-form-group mb-4">
            <label asp-for="Notes" class="form-label text-secondary fw-semibold mb-2">Ghi chú đơn hàng</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-info">
                    <i class="bi bi-chat-left-text-fill"></i>
                </span>
                <textarea asp-for="Notes" rows="4" class="form-control custom-form-control" placeholder="Ghi chú thời gian nhận hàng, chỉ dẫn giao hàng..."></textarea>
            </div>
            <span asp-validation-for="Notes" class="text-danger small mt-1 d-block"></span>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top border-secondary">
            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2">
                <i class="bi bi-arrow-left me-1"></i> Trở lại giỏ hàng
            </a>
            <button type="submit" class="btn btn-premium-emerald px-5 py-2">
                <i class="bi bi-bag-check-fill me-2"></i> Xác nhận đặt hàng
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
