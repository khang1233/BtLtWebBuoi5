@using Microsoft.AspNetCore.Http
@using Baitaptuan5.Extensions
@using Baitaptuan5.Models
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TranMinhKhang_Tuan5</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Baitaptuan5.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark custom-navbar mb-4">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop me-2 fs-4 text-info"></i>
                    <span>TranMinhKhang_Tuan5</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" 
                               asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Trang chủ
                            </a>
                        </li>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin") || User.IsInRole("Employee") || User.IsInRole("Company"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "Admin" && ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")" 
                                       asp-area="Admin" asp-controller="Product" asp-action="Index">
                                        <i class="bi bi-box-seam me-1"></i> Quản lý sản phẩm
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "Admin" && ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")" 
                                       asp-area="Admin" asp-controller="Categories" asp-action="Index">
                                        <i class="bi bi-tags me-1"></i> Quản lý danh mục
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "Admin" && ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")" 
                                       asp-area="Admin" asp-controller="Order" asp-action="Index">
                                        <i class="bi bi-receipt me-1"></i> Quản lý đơn hàng
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    
                    <ul class="navbar-nav">
                        @{
                            var session = HttpContextAccessor.HttpContext?.Session;
                            var cart = session != null ? session.GetObjectFromJson<ShoppingCart>("Cart") : null;
                            var itemCount = cart?.Items.Sum(i => i.Quantity) ?? 0;
                        }
                        <li class="nav-item me-3">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ShoppingCart" ? "active" : "") d-flex align-items-center" 
                               asp-area="" asp-controller="ShoppingCart" asp-action="Index">
                                <i class="bi bi-cart3 me-1 fs-5 text-info"></i>
                                <span>Giỏ hàng</span>
                                @if (itemCount > 0)
                                {
                                    <span class="badge rounded-pill bg-danger ms-1">@itemCount</span>
                                }
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex align-items-center me-3">
                                <span class="text-light-emphasis">
                                    <i class="bi bi-person-circle me-1 text-info"></i> Xin chào, <strong>@User.Identity.Name</strong>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <span class="badge bg-danger ms-1">Admin</span>
                                    }
                                    else if (User.IsInRole("Employee"))
                                    {
                                        <span class="badge bg-info ms-1">Employee</span>
                                    }
                                    else if (User.IsInRole("Company"))
                                    {
                                        <span class="badge bg-primary ms-1">Company</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success ms-1">Customer</span>
                                    }
                                </span>
                            </li>
                            <li class="nav-item">
                                <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="nav-link btn btn-link text-decoration-none border-0 bg-transparent">
                                        <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" && ViewContext.RouteData.Values["action"]?.ToString() == "Login" ? "active" : "")" 
                                   asp-area="" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" && ViewContext.RouteData.Values["action"]?.ToString() == "Register" ? "active" : "")" 
                                   asp-area="" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i> Đăng ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container pb-5">
        <main role="main">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-custom alert-custom-success mb-4">
                    <i class="bi bi-check-circle-fill fs-5"></i>
                    <div>@TempData["SuccessMessage"]</div>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-custom alert-custom-error mb-4">
                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    <div>@TempData["ErrorMessage"]</div>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="footer-nav">
        <div class="container text-center text-secondary">
            <p class="mb-1">&copy; 2026 - TranMinhKhang_Tuan5. Nền tảng bán hàng cao cấp.</p>
            <small>Phát triển bởi Antigravity & TranMinhKhang_Tuan5</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
