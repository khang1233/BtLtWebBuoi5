@model Baitaptuan5.Models.Product
@{
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="mb-4">
    <h2 class="fw-bold mb-1"><i class="bi bi-plus-circle text-info me-2"></i> Thêm sản phẩm mới</h2>
    <p class="text-secondary mb-0">Tạo một sản phẩm mới trong danh mục hàng hóa</p>
</div>

<div class="glass-panel p-4" style="max-width: 700px; margin: 0 auto;">
    <form asp-action="Add" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group custom-form-group mb-3">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control custom-form-control" placeholder="Nhập tên sản phẩm..." />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="form-group custom-form-group">
                    <label asp-for="Price"></label>
                    <div class="input-group">
                        <input type="text" id="formattedPrice" class="form-control custom-form-control border-end-0" placeholder="Giá..." />
                        <input type="hidden" asp-for="Price" id="realPrice" />
                        <span class="input-group-text bg-transparent border-light border-opacity-10 text-secondary">đ</span>
                    </div>
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="form-group custom-form-group">
                    <label asp-for="CategoryId"></label>
                    <select asp-for="CategoryId" asp-items="@((SelectList)ViewBag.Categories)" class="form-control custom-form-control custom-form-select">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="form-group custom-form-group mb-3">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" rows="4" class="form-control custom-form-control" placeholder="Mô tả chi tiết sản phẩm..."></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <!-- Image Upload with Real-time JS Preview (Lab 3, Page 53) -->
        <div class="form-group custom-form-group mb-3">
            <label>Hình ảnh sản phẩm</label>
            <input type="file" name="imageFile" id="imageInput" class="form-control custom-form-control" accept="image/*" onchange="previewImage(event)" />
            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <div id="previewContainer" style="display: none;">
                <p class="text-secondary small mb-2">Xem trước hình ảnh:</p>
                <img id="imagePreview" src="#" alt="Xem trước ảnh" class="rounded border border-light border-opacity-10 shadow-sm" style="max-width: 100%; max-height: 250px; object-fit: contain;" />
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center border-top border-light border-opacity-10 pt-3 mt-4">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
            </a>
            <button type="submit" class="btn btn-premium-primary">
                <i class="bi bi-save me-1"></i> Thêm sản phẩm
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        function previewImage(event) {
            const input = event.target;
            const container = document.getElementById('previewContainer');
            const preview = document.getElementById('imagePreview');
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    container.style.display = 'block';
                }
                
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.src = '#';
                container.style.display = 'none';
            }
        }

        // Price formatting logic
        function formatNumber(val) {
            if (!val) return '';
            val = val.toString().replace(/\D/g, '');
            return val.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        }

        const formattedInput = document.getElementById('formattedPrice');
        const realInput = document.getElementById('realPrice');

        if (formattedInput && realInput) {
            if (realInput.value) {
                let val = Math.round(parseFloat(realInput.value.replace(',', '.'))) || '';
                formattedInput.value = formatNumber(val);
            }

            formattedInput.addEventListener('input', function(e) {
                let cleaned = this.value.replace(/\./g, '').replace(/\D/g, '');
                realInput.value = cleaned;
                this.value = formatNumber(cleaned);
            });
        }
    </script>
}
