@model Baitaptuan5.Models.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm - " + Model.Name;
}

<div class="mb-4">
    <h2 class="fw-bold mb-1"><i class="bi bi-eye text-info me-2"></i> Chi tiết sản phẩm</h2>
    <p class="text-secondary mb-0">Xem thông tin chi tiết của sản phẩm trong hệ thống</p>
</div>

<div class="glass-panel p-4" style="max-width: 800px; margin: 0 auto;">
    <div class="row g-4">
        <div class="col-md-5 text-center">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded border border-light border-opacity-10 shadow-sm" style="max-height: 350px; object-fit: contain; width: 100%;" />
            }
            else
            {
                <div class="bg-secondary rounded text-center d-flex align-items-center justify-content-center border border-light border-opacity-10 shadow-sm" style="height: 250px; width: 100%;">
                    <i class="bi bi-image text-muted fs-1"></i>
                </div>
            }
        </div>
        
        <div class="col-md-7 d-flex flex-column justify-content-between">
            <div>
                <span class="badge bg-info text-dark mb-2">@(Model.Category?.Name ?? "Không có danh mục")</span>
                <h3 class="fw-bold text-light mb-2">@Model.Name</h3>
                
                <div class="fs-4 fw-bold text-info mb-3">
                    @Model.Price.ToString("#,##0", new System.Globalization.CultureInfo("vi-VN")) đ
                </div>
                
                <h5 class="text-light-emphasis border-bottom border-light border-opacity-10 pb-2 mb-2">Mô tả sản phẩm</h5>
                <p class="text-secondary" style="white-space: pre-wrap; line-height: 1.6;">
                    @(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả cho sản phẩm này." : Model.Description)
                </p>
            </div>
            
            <div class="d-flex justify-content-between align-items-center border-top border-light border-opacity-10 pt-3 mt-4">
                @if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Employee")))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
                    </a>
                }
                else
                {
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại cửa hàng
                    </a>
                }
                
                <div class="d-flex gap-2">
                    @if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Employee")))
                    {
                        <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-premium-emerald">
                            <i class="bi bi-pencil me-1"></i> Sửa sản phẩm
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-premium-danger">
                            <i class="bi bi-trash me-1"></i> Xóa
                        </a>
                    }
                    else
                    {
                        <a asp-area="" asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@Model.Id" asp-route-quantity="1" class="btn btn-premium-primary px-4">
                            <i class="bi bi-cart-plus-fill me-1"></i> Thêm vào giỏ hàng
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
