@model Baitaptuan5.Models.Product
@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="mb-4">
    <h2 class="fw-bold mb-1"><i class="bi bi-trash text-danger me-2"></i> Xóa sản phẩm</h2>
    <p class="text-secondary mb-0">Xác nhận xóa sản phẩm khỏi hệ thống cơ sở dữ liệu</p>
</div>

<div class="glass-panel p-4" style="max-width: 600px; margin: 0 auto;">
    <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger mb-4">
        <i class="bi bi-exclamation-triangle-fill fs-5 me-2"></i>
        <strong>Cảnh báo!</strong> Bạn có chắc chắn muốn xóa sản phẩm này? Hành động này không thể hoàn tác.
    </div>

    <div class="d-flex align-items-start gap-4 mb-4">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" class="rounded border border-light border-opacity-10 shadow-sm" style="max-width: 150px; max-height: 150px; object-fit: contain;" />
        }
        else
        {
            <div class="bg-secondary rounded text-center d-flex align-items-center justify-content-center border border-light border-opacity-10" style="width: 120px; height: 120px;">
                <i class="bi bi-image text-muted fs-2"></i>
            </div>
        }
        
        <div>
            <h4 class="fw-bold text-light mb-1">@Model.Name</h4>
            <div class="text-info fw-bold fs-5 mb-2">@Model.Price.ToString("#,##0", new System.Globalization.CultureInfo("vi-VN")) đ</div>
            <p class="text-secondary small mb-1"><strong>Danh mục:</strong> @(Model.Category?.Name ?? "Không có")</p>
            <p class="text-secondary small mb-0"><strong>Mô tả:</strong> @(string.IsNullOrEmpty(Model.Description) ? "Không có" : Model.Description)</p>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex justify-content-between align-items-center border-top border-light border-opacity-10 pt-3">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <button type="submit" class="btn btn-premium-danger">
                <i class="bi bi-trash-fill me-1"></i> Đồng ý xóa
            </button>
        </div>
    </form>
</div>
