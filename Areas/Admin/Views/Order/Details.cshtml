@model Baitaptuan5.Models.Order
@{
    ViewData["Title"] = $"Chi Tiết Đơn Hàng #{Model.Id} - Admin";
}

<div class="glass-panel p-5 my-4">
    <div class="text-center mb-5 pb-3 border-bottom border-secondary">
        <h2 class="h3 fw-bold mb-0 text-light">
            🛒 Chi Tiết Đơn Hàng
        </h2>
    </div>

    <!-- Thông tin khách hàng -->
    <div class="mb-5">
        <h4 class="h5 fw-bold text-info mb-3">
            🧑 Thông Tin Khách Hàng
        </h4>
        <div class="p-3 rounded" style="background: rgba(30, 41, 59, 0.35); border: 1px solid var(--glass-border);">
            <table class="table table-borderless text-light mb-0">
                <tr>
                    <td class="text-secondary ps-0" style="width: 180px;">👤 Tên:</td>
                    <td><strong>@(Model.ApplicationUser?.FullName ?? "N/A")</strong></td>
                </tr>
                <tr>
                    <td class="text-secondary ps-0">✉️ Email:</td>
                    <td>@(Model.ApplicationUser?.Email ?? "N/A")</td>
                </tr>
                <tr>
                    <td class="text-secondary ps-0">📞 Số điện thoại:</td>
                    <td>@(Model.ApplicationUser?.PhoneNumber ?? "N/A")</td>
                </tr>
            </table>
        </div>
    </div>

    <!-- Thông tin đặt hàng -->
    <div class="mb-5">
        <h4 class="h5 fw-bold text-info mb-3">
            💼 Thông Tin Đặt Hàng
        </h4>
        <div class="p-3 rounded" style="background: rgba(30, 41, 59, 0.35); border: 1px solid var(--glass-border);">
            <table class="table table-borderless text-light mb-0">
                <tr>
                    <td class="text-secondary ps-0" style="width: 180px;">💼 Mã đơn:</td>
                    <td><strong>#@Model.Id</strong></td>
                </tr>
                <tr>
                    <td class="text-secondary ps-0">📅 Ngày đặt:</td>
                    <td>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm:ss")</td>
                </tr>
                <tr>
                    <td class="text-secondary ps-0">📍 Địa chỉ giao hàng:</td>
                    <td>@Model.ShippingAddress</td>
                </tr>
                <tr>
                    <td class="text-secondary ps-0">📝 Ghi chú của khách:</td>
                    <td>
                        @if (string.IsNullOrEmpty(Model.Notes))
                        {
                            <span class="text-secondary italic">Không có ghi chú</span>
                        }
                        else
                        {
                            @Model.Notes
                        }
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <!-- Sản phẩm trong đơn hàng -->
    <div class="mb-4">
        <h4 class="h5 fw-bold text-success mb-3">
            📦 Sản Phẩm Trong Đơn Hàng
        </h4>
        <div class="table-responsive">
            <table class="custom-table text-light">
                <thead>
                    <tr>
                        <th style="width: 120px;">Mã sản phẩm</th>
                        <th>Tên sản phẩm</th>
                        <th style="width: 100px; text-align: center;">Số lượng</th>
                        <th>Giá</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderDetails)
                    {
                        <tr>
                            <td>
                                <span class="text-info">#@item.ProductId</span>
                            </td>
                            <td>
                                <strong class="text-light">@(item.Product?.Name ?? "Sản phẩm đã bị xóa")</strong>
                            </td>
                            <td class="text-center">
                                @item.Quantity
                            </td>
                            <td class="text-secondary">
                                @item.Price.ToString("#,##0", new System.Globalization.CultureInfo("vi-VN")) đ
                            </td>
                            <td class="text-info fw-bold text-end">
                                @((item.Price * item.Quantity).ToString("#,##0", new System.Globalization.CultureInfo("vi-VN"))) đ
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Tổng tiền & Nút quay lại -->
    <div class="d-flex flex-column align-items-center mt-5 pt-4 border-top border-secondary">
        <div class="w-100 text-end mb-4">
            <h4 class="text-danger fw-bold fs-4">
                💰 Tổng tiền: @Model.TotalPrice.ToString("#,##0", new System.Globalization.CultureInfo("vi-VN")) đ
            </h4>
        </div>
        <a asp-action="Index" class="btn btn-premium-primary px-5 py-2">
            ⬅️ Quay lại danh sách
        </a>
    </div>
</div>
