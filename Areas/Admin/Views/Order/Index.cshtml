@model IEnumerable<Baitaptuan5.Models.Order>
@{
    ViewData["Title"] = "Quản Lý Đơn Hàng - Admin";
}

<div class="glass-panel p-5 my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 fw-bold mb-0 text-light">
            <i class="bi bi-receipt text-info me-2"></i> Danh sách đơn hàng
        </h2>
        <span class="badge bg-info px-3 py-2 fs-6">
            Tổng số đơn: @Model.Count()
        </span>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inboxes fs-1 text-secondary mb-3 d-block"></i>
            <h4 class="text-light fw-bold">Chưa có đơn hàng nào</h4>
            <p class="text-secondary">Hệ thống chưa ghi nhận đơn đặt hàng nào từ người dùng.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="custom-table text-light">
                <thead>
                    <tr>
                        <th style="width: 80px;">Mã ĐH</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Địa chỉ giao hàng</th>
                        <th style="width: 150px; text-align: center;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong class="text-info">#@item.Id</strong>
                            </td>
                            <td>
                                <div>
                                    <strong class="text-light">@(item.ApplicationUser?.FullName ?? "N/A")</strong>
                                    <div class="text-secondary small">@(item.ApplicationUser?.Email ?? "N/A")</div>
                                </div>
                            </td>
                            <td>
                                @item.OrderDate.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="text-info fw-bold">
                                @item.TotalPrice.ToString("#,##0", new System.Globalization.CultureInfo("vi-VN")) đ
                            </td>
                            <td>
                                <span class="d-inline-block text-truncate" style="max-width: 250px;" title="@item.ShippingAddress">
                                    @item.ShippingAddress
                                </span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-premium-primary btn-sm px-3">
                                    <i class="bi bi-search me-1"></i> Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
