@model Baitaptuan5.Models.Category
@{
    ViewData["Title"] = "Xóa danh mục";
}

<div class="mb-4">
    <h2 class="fw-bold mb-1"><i class="bi bi-trash text-danger me-2"></i> Xóa danh mục</h2>
    <p class="text-secondary mb-0">Xác nhận xóa danh mục khỏi cơ sở dữ liệu</p>
</div>

<div class="glass-panel p-4" style="max-width: 600px; margin: 0 auto;">
    <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger mb-4">
        <i class="bi bi-exclamation-triangle-fill fs-5 me-2"></i>
        <strong>Cảnh báo!</strong> Bạn có chắc chắn muốn xóa danh mục này? Tất cả sản phẩm thuộc danh mục này cũng có thể bị xóa hoặc mất liên kết (Xóa liên hoàn - Cascade delete).
    </div>

    <div class="mb-4">
        <span class="text-secondary small d-block mb-1">Mã Danh Mục:</span>
        <strong class="text-secondary">#@Model.Id</strong>

        <span class="text-secondary small d-block mt-3 mb-1">Tên Danh Mục:</span>
        <h4 class="text-light fw-bold">@Model.Name</h4>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex justify-content-between align-items-center border-top border-light border-opacity-10 pt-3">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <button type="submit" class="btn btn-premium-danger">
                <i class="bi bi-trash-fill me-1"></i> Đồng ý xóa
            </button>
        </div>
    </form>
</div>
