@model Baitaptuan5.Models.Category
@{
    ViewData["Title"] = "Thêm danh mục mới";
}

<div class="mb-4">
    <h2 class="fw-bold mb-1"><i class="bi bi-plus-circle text-info me-2"></i> Thêm danh mục mới</h2>
    <p class="text-secondary mb-0">Tạo một phân loại sản phẩm mới trong cửa hàng</p>
</div>

<div class="glass-panel p-4" style="max-width: 600px; margin: 0 auto;">
    <form asp-action="Add" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group custom-form-group mb-4">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control custom-form-control" placeholder="Nhập tên danh mục..." />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="d-flex justify-content-between align-items-center border-top border-light border-opacity-10 pt-3">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <button type="submit" class="btn btn-premium-primary">
                <i class="bi bi-save me-1"></i> Thêm danh mục
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

