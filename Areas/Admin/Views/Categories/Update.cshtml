@model Baitaptuan5.Models.Category
@{
    ViewData["Title"] = "Cập nhật danh mục";
}

<div class="mb-4">
    <h2 class="fw-bold mb-1"><i class="bi bi-pencil text-info me-2"></i> Cập nhật danh mục</h2>
    <p class="text-secondary mb-0">Chá»‰nh sửa tên danh mục: <strong>@Model.Name</strong></p>
</div>

<div class="glass-panel p-4" style="max-width: 600px; margin: 0 auto;">
    <form asp-action="Update" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="form-group custom-form-group mb-4">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control custom-form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="d-flex justify-content-between align-items-center border-top border-light border-opacity-10 pt-3">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <button type="submit" class="btn btn-premium-emerald">
                <i class="bi bi-check-circle me-1"></i> Lưu thay đổi
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

