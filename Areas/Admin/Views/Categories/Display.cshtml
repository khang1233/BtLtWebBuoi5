@model Baitaptuan5.Models.Category
@{
    ViewData["Title"] = "Chi tiết danh mục - " + Model.Name;
}

<div class="mb-4">
    <h2 class="fw-bold mb-1"><i class="bi bi-eye text-info me-2"></i> Chi tiết danh mục</h2>
    <p class="text-secondary mb-0">Xem thông tin chi tiết của danh mục</p>
</div>

<div class="glass-panel p-4" style="max-width: 600px; margin: 0 auto;">
    <div class="mb-4">
        <h5 class="text-secondary small mb-1">Mã Danh Mục:</h5>
        <div class="text-secondary fs-6 mb-3">#@Model.Id</div>

        <h5 class="text-secondary small mb-1">Tên Danh Mục:</h5>
        <div class="text-light fs-4 fw-bold mb-3">@Model.Name</div>
    </div>

    <div class="d-flex justify-content-between align-items-center border-top border-light border-opacity-10 pt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
        <div class="d-flex gap-2">
            <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-premium-emerald">
                <i class="bi bi-pencil me-1"></i> Sửa danh mục
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-premium-danger">
                <i class="bi bi-trash me-1"></i> Xóa
            </a>
        </div>
    </div>
</div>

